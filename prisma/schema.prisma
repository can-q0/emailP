generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  patients      Patient[]
  reports       Report[]
  emailSyncLogs EmailSyncLog[]
  settings      UserSettings?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id           String        @id @default(cuid())
  name         String
  governmentId String?
  email        String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails       Email[]
  bloodMetrics BloodMetric[]
  reports      Report[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([governmentId, userId])
  @@index([name, userId])
}

model Email {
  id              String        @id @default(cuid())
  gmailMessageId  String        @unique
  threadId        String?
  subject         String?
  from            String?
  to              String?
  date            DateTime?
  snippet         String?
  body            String?
  htmlBody        String?
  labels          String        @default("[]")
  isLabReport     Boolean       @default(false)
  extractedData   String?
  patientId       String?
  patient         Patient?      @relation(fields: [patientId], references: [id])
  reportEmails    ReportEmail[]
  userId          String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, date])
  @@index([patientId])
}

model BloodMetric {
  id             String   @id @default(cuid())
  metricName     String
  value          Float
  unit           String
  referenceMin   Float?
  referenceMax   Float?
  isAbnormal     Boolean  @default(false)
  measuredAt     DateTime
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reportId       String?
  report         Report?  @relation(fields: [reportId], references: [id])
  createdAt      DateTime @default(now())

  @@index([patientId, metricName, measuredAt])
  @@index([reportId])
}

model Report {
  id              String        @id @default(cuid())
  title           String
  summary         String?
  attentionPoints String?
  status          String        @default("pending")
  step            String?
  reportType      String        @default("detailed report")
  format          String        @default("detailed")
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportEmails    ReportEmail[]
  bloodMetrics    BloodMetric[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([patientId])
}

model ReportEmail {
  id       String @id @default(cuid())
  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  emailId  String
  email    Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@unique([reportId, emailId])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiModel            String   @default("gpt-5")
  reportLanguage     String   @default("en")
  reportDetailLevel  String   @default("detailed")
  customSystemPrompt String?
  autoClassify       Boolean  @default(true)
  displayName        String?
  theme              String   @default("light")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EmailSyncLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String
  emailsFound Int      @default(0)
  emailsSynced Int     @default(0)
  status      String   @default("pending")
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
